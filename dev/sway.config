# Minimal development Sway config for vibeshell.

set $mod Mod4

# Launch terminal.
bindsym $mod+Return exec foot

# Panel toggle.
# Requires `panel` on PATH (e.g. `cargo install --path apps/panel` from this repo).
# If panel exists, close it. Otherwise start it.
bindsym $mod+p exec swaymsg '[app_id="com.vibeshell.panel"] kill' || panel

# Close launcher quickly.
bindsym Escape exec swaymsg '[app_id="com.vibeshell.launcher"] kill'

# Generated keybindings (launcher toggle, screenshot, media keys, shell controls).
include sway.bindings.generated
