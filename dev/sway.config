# Minimal development Sway config for vibeshell.

set $mod Mod4

# Launch terminal.
bindsym $mod+Return exec foot

# Placeholder: future panel command.
bindsym $mod+p exec echo "TODO: start panel"

# Placeholder: future launcher command.
bindsym $mod+d exec echo "TODO: start launcher"

# Exit nested session.
bindsym $mod+Shift+e exec swaymsg exit
